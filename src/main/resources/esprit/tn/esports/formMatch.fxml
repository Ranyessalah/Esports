<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="esprit.tn.esports.controller.FormMatchController"
            stylesheets="@admin.css"
            styleClass="root">

    <!-- MAIN -->
    <center>
        <VBox spacing="20" styleClass="main-content">
            <padding>
                <Insets top="30" right="35" bottom="30" left="35"/>
            </padding>

            <!-- HEADER -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label fx:id="formTitleLabel" text="Ajouter un Match" styleClass="page-title"/>
                    <Label text="Configurez les détails de l'affrontement." styleClass="page-subtitle"/>
                </VBox>
                <Button text="Fermer" onAction="#closeWindow" styleClass="btn-secondary"/>
            </HBox>

            <!-- FORM SCROLL -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane-custom">
                <content>
                    <VBox spacing="25">
                        
                        <!-- CARD 1: GENERAL INFO -->
                        <VBox spacing="20" styleClass="form-section-card">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="📝" styleClass="form-icon-label"/>
                                <Label text="Généralités" styleClass="section-title" style="-fx-font-size: 18px;"/>
                            </HBox>

                            <VBox spacing="8">
                                <Label text="Nom du match *" styleClass="form-label"/>
                                <TextField fx:id="nomField" promptText="Ex : Finale Valorant 2026" styleClass="form-input"/>
                                <Label fx:id="nomError" styleClass="error-label" visible="false" managed="false"/>
                            </VBox>
                        </VBox>

                        <!-- CARD 2: VERSUS SECTION (SCOREBOARD) -->
                        <VBox spacing="25" styleClass="scoreboard-card">
                            <HBox alignment="CENTER" spacing="40">
                                
                                <!-- TEAM 1 -->
                                <VBox spacing="18" alignment="CENTER" HBox.hgrow="ALWAYS">
                                    <Label text="ÉQUIPE 1" styleClass="form-label" style="-fx-text-fill: #aab3c5; -fx-font-weight: 800;"/>
                                    
                                    <!-- LOGO 1 -->
                                    <StackPane style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 50;">
                                        <ImageView fx:id="logo1" fitWidth="80" fitHeight="80" preserveRatio="true"/>
                                    </StackPane>

                                    <ComboBox fx:id="equipe1Box" promptText="Choisir Equipe" maxWidth="Infinity" styleClass="form-combo" prefHeight="45"/>
                                    
                                    <HBox spacing="20" alignment="CENTER">
                                        <Button fx:id="decScore1Btn" text="−" onAction="#decreaseScore1" styleClass="score-stepper-btn"/>
                                        <Label fx:id="score1Display" text="0" styleClass="score-value" style="-fx-font-size: 56px; -fx-text-fill: #22c55e;"/>
                                        <Button fx:id="incScore1Btn" text="+" onAction="#increaseScore1" styleClass="score-stepper-btn"/>
                                    </HBox>
                                    <Label fx:id="equipe1Error" styleClass="error-label" visible="false" managed="false"/>
                                    <Label fx:id="score1Error" styleClass="error-label" visible="false" managed="false"/>
                                </VBox>

                                <Label text="VS" styleClass="vs-label" style="-fx-font-size: 42px; -fx-opacity: 0.3; -fx-padding: 20 0 0 0;"/>

                                <!-- TEAM 2 -->
                                <VBox spacing="18" alignment="CENTER" HBox.hgrow="ALWAYS">
                                    <Label text="ÉQUIPE 2" styleClass="form-label" style="-fx-text-fill: #aab3c5; -fx-font-weight: 800;"/>
                                    
                                    <!-- LOGO 2 -->
                                    <StackPane style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 50;">
                                        <ImageView fx:id="logo2" fitWidth="80" fitHeight="80" preserveRatio="true"/>
                                    </StackPane>

                                    <ComboBox fx:id="equipe2Box" promptText="Choisir Equipe" maxWidth="Infinity" styleClass="form-combo" prefHeight="45"/>
                                    
                                    <HBox spacing="20" alignment="CENTER">
                                        <Button fx:id="decScore2Btn" text="−" onAction="#decreaseScore2" styleClass="score-stepper-btn"/>
                                        <Label fx:id="score2Display" text="0" styleClass="score-value" style="-fx-font-size: 56px; -fx-text-fill: #3b82f6;"/>
                                        <Button fx:id="incScore2Btn" text="+" onAction="#increaseScore2" styleClass="score-stepper-btn"/>
                                    </HBox>
                                    <Label fx:id="equipe2Error" styleClass="error-label" visible="false" managed="false"/>
                                    <Label fx:id="score2Error" styleClass="error-label" visible="false" managed="false"/>
                                </VBox>
                            </HBox>

                            <!-- Hidden Fields for Logic -->
                            <TextField fx:id="score1Field" visible="false" managed="false" text="0"/>
                            <TextField fx:id="score2Field" visible="false" managed="false" text="0"/>
                        </VBox>

                        <!-- CARD 3: SCHEDULE -->
                        <VBox spacing="20" styleClass="form-section-card">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="📅" styleClass="form-icon-label"/>
                                <Label text="Planification" styleClass="section-title" style="-fx-font-size: 18px;"/>
                            </HBox>

                            <GridPane hgap="30" vgap="25">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="60"/>
                                    <ColumnConstraints percentWidth="40"/>
                                </columnConstraints>

                                <!-- DEBUT -->
                                <VBox spacing="8" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                    <Label text="Date du Match *" styleClass="form-label"/>
                                    <DatePicker fx:id="dateMatchPicker" maxWidth="Infinity" styleClass="form-input" prefHeight="45"/>
                                    <Label fx:id="dateMatchError" styleClass="error-label" visible="false" managed="false"/>
                                </VBox>
                                <VBox spacing="8" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <Label text="Heure Début *" styleClass="form-label"/>
                                    <ComboBox fx:id="hourStartBox" maxWidth="Infinity" styleClass="form-combo" prefHeight="45"/>
                                </VBox>

                            </GridPane>

                            <!-- STATUS (conditional) -->
                            <VBox spacing="10" fx:id="statusBox" visible="false" managed="false">
                                <Separator style="-fx-opacity: 0.1;"/>
                                <Label text="Statut du match" styleClass="form-label"/>
                                <ComboBox fx:id="statusBoxField" maxWidth="Infinity" styleClass="form-combo" prefHeight="45"/>
                            </VBox>
                        </VBox>

                        <!-- GLOBAL ERROR -->
                        <Label fx:id="errorLabel" visible="false" managed="false" wrapText="true" styleClass="error-label"/>

                        <!-- ACTIONS -->
                        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 20 0;">
                            <Button text="📅 Google Calendar" onAction="#openGoogleCalendarEvent" styleClass="btn-secondary" prefHeight="45"/>
                            <Button text="Annuler" onAction="#closeWindow" styleClass="btn-cancel" prefHeight="45" prefWidth="120"/>
                            <Button fx:id="saveBtn" text="Enregistrer" onAction="#saveMatch" styleClass="btn-success-lg" prefHeight="45" prefWidth="160"/>
                        </HBox>

                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>