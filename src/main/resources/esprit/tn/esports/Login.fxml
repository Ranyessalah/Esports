<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane prefHeight="760.0" prefWidth="1200.0" style="-fx-background-color: #12101F;" stylesheets="@login.css" xmlns="http://javafx.com/javafx/21.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="esprit.tn.esports.controller.LoginController">
   <children>
      <VBox alignment="CENTER" maxWidth="350.0" maxHeight="600.0" spacing="15.0" styleClass="login-card">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <children>
            <!-- Logo placeholder -->
            <StackPane prefHeight="50.0" prefWidth="50.0" styleClass="logo-container">
               <children>
                  <Label text="🎮" textFill="WHITE">
                     <font>
                        <Font size="28.0" />
                     </font>
                  </Label>
               </children>
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </StackPane>
            
            <Label text="Bon retour !" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font>
            </Label>
            <Label text="Connectez-vous à votre compte ClutchX" textFill="#8c8b99">
               <font>
                  <Font size="12.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </Label>
            
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="social-btn" text="G Se connecter avec Google" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="social-btn" text="📷 Se connecter avec Face ID" />
            
            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <Separator HBox.hgrow="ALWAYS" />
                  <Label text="OU" textFill="#8c8b99">
                     <font>
                        <Font size="10.0" />
                     </font>
                  </Label>
                  <Separator HBox.hgrow="ALWAYS" />
               </children>
               <VBox.margin>
                  <Insets bottom="5.0" top="5.0" />
               </VBox.margin>
            </HBox>
            
            <VBox spacing="5.0">
               <children>
                  <Label text="EMAIL" textFill="#8c8b99">
                     <font>
                        <Font name="System Bold" size="10.0" />
                     </font>
                  </Label>
                  <TextField fx:id="emailField" promptText="exemple@email.com" styleClass="input-field" />
               </children>
            </VBox>
            
            <VBox spacing="5.0">
               <children>
                  <Label text="MOT DE PASSE" textFill="#8c8b99">
                     <font>
                        <Font name="System Bold" size="10.0" />
                     </font>
                  </Label>
                  <PasswordField fx:id="passwordField" promptText="Entrez votre mot de passe" styleClass="input-field" />
               </children>
            </VBox>
            
            <HBox alignment="CENTER_LEFT">
               <children>
                  <CheckBox mnemonicParsing="false" styleClass="remember-me" text="Se souvenir de moi" textFill="#8c8b99">
                     <font>
                        <Font size="11.0" />
                     </font>
                  </CheckBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label styleClass="forgot-password" text="Mot de passe oublié ?" textFill="#7d5fff">
                     <font>
                        <Font size="11.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            
            <HBox alignment="CENTER_LEFT" prefHeight="40.0" spacing="10.0" styleClass="recaptcha-container">
               <children>
                  <CheckBox mnemonicParsing="false" text="Je ne suis pas un robot" textFill="#8c8b99" />
                  <Region HBox.hgrow="ALWAYS" />
                  <VBox alignment="CENTER">
                     <children>
                        <Label text="reCAPTCHA" textFill="#8c8b99">
                           <font>
                              <Font name="System Bold" size="9.0" />
                           </font>
                        </Label>
                        <Label text="Confidentialité - Conditions" textFill="#8c8b99">
                           <font>
                              <Font size="7.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="10.0" left="15.0" right="15.0" top="10.0" />
               </padding>
            </HBox>
            
            <Label fx:id="errorLabel" text="" textFill="#ff4d4d">
               <font>
                  <Font size="12.0" />
               </font>
            </Label>
            
            <Button fx:id="loginButton" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleLogin" styleClass="primary-btn" text="→  Se connecter">
               <VBox.margin>
                  <Insets top="5.0" />
               </VBox.margin>
            </Button>
            
            <Label text="Pas encore de compte ?" textFill="#8c8b99">
               <font>
                  <Font size="12.0" />
               </font>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </Label>
            
            <HBox alignment="CENTER" spacing="10.0">
               <children>
                  <Button mnemonicParsing="false" styleClass="secondary-btn" text="🎮 Inscription Joueur" />
                  <Button mnemonicParsing="false" styleClass="secondary-btn" text="🏆 Inscription Coach" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</StackPane>
