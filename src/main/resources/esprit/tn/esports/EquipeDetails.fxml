<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="esprit.tn.esports.controller.EquipeDetailsController"
            stylesheets="@admin.css"
            styleClass="root">

    <!-- HEADER -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="20">
            <Button text="⬅ Retour" onAction="#goBack" styleClass="btn-secondary"/>
            <Label text="🎮 Equipes Details" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <!-- CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane-custom">
            <content>
                <VBox spacing="35" styleClass="details-wrapper">

                    <!-- TEAM HEADER PREMIUM -->
                    <HBox spacing="40" alignment="CENTER_LEFT" styleClass="team-header-premium">
                        <ImageView fx:id="logo" fitWidth="160" fitHeight="160" preserveRatio="true"/>
                        <VBox spacing="15" alignment="CENTER_LEFT">
                            <Label fx:id="name" styleClass="big-title" style="-fx-font-size: 36px;"/>
                            <HBox spacing="15">
                                <Label fx:id="game" styleClass="badge" style="-fx-background-color: #7c3aed;"/>
                                <Label fx:id="category" styleClass="badge" style="-fx-background-color: #3b82f6;"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- STATS SECTION -->
                    <HBox spacing="25">
                        <VBox styleClass="stat-pill" HBox.hgrow="ALWAYS">
                            <Label text="MEMBRES" styleClass="stat-title"/>
                            <Label fx:id="nbPlayers" styleClass="stat-value"/>
                        </VBox>

                        <VBox styleClass="stat-pill" HBox.hgrow="ALWAYS">
                            <Label text="DISCIPLINE" styleClass="stat-title"/>
                            <Label fx:id="gameStat" styleClass="stat-value"/>
                        </VBox>
                    </HBox>

                    <!-- STAFF SECTION -->
                    <VBox fx:id="staffSection" spacing="20">
                        <Label text="Staff Technique" styleClass="section-title"/>
                        <FlowPane fx:id="staffContainer"
                                  hgap="20"
                                  vgap="20"
                                  prefWrapLength="1000"/>
                    </VBox>

                    <!-- PLAYERS LIST -->
                    <VBox spacing="20">
                        <Label text="Liste des Joueurs" styleClass="section-title"/>
                        <FlowPane fx:id="playersContainer"
                                  hgap="20"
                                  vgap="20"
                                  prefWrapLength="1000"/>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>