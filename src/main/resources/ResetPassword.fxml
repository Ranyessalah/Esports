<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ResetPasswordController"
            fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            styleClass="signup-scroll">
    <VBox styleClass="signup-bg-overlay" alignment="CENTER" minHeight="600" spacing="0">
        <padding><Insets top="30" bottom="30" left="20" right="20"/></padding>
        <VBox styleClass="signup-card" spacing="0" alignment="CENTER" maxWidth="420" minWidth="280">
            <padding><Insets top="36" bottom="36" left="32" right="32"/></padding>

            <StackPane alignment="CENTER" styleClass="trophy-icon-container">
                <Label text="🔒" styleClass="trophy-icon"/>
            </StackPane>

            <Label text="Nouveau mot de passe" styleClass="signup-title"
                   wrapText="true" textAlignment="CENTER" maxWidth="Infinity" alignment="CENTER"/>
            <Label text="Choisissez un mot de passe fort"
                   styleClass="signup-subtitle" wrapText="true"
                   textAlignment="CENTER" maxWidth="Infinity" alignment="CENTER"/>

            <VBox spacing="16" styleClass="form-fields">
                <VBox.margin><Insets top="28"/></VBox.margin>

                <VBox spacing="4">
                    <Label text="NOUVEAU MOT DE PASSE" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField" styleClass="dark-input"
                                   promptText="Minimum 8 caractères" maxWidth="Infinity"/>
                    <!-- Barre de force -->
                    <HBox spacing="4" fx:id="strengthBar">
                        <Region fx:id="seg1" styleClass="strength-segment" HBox.hgrow="ALWAYS"/>
                        <Region fx:id="seg2" styleClass="strength-segment" HBox.hgrow="ALWAYS"/>
                        <Region fx:id="seg3" styleClass="strength-segment" HBox.hgrow="ALWAYS"/>
                        <Region fx:id="seg4" styleClass="strength-segment" HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <Label fx:id="strengthLabel" styleClass="strength-text"
                           visible="false" managed="false"/>
                    <Label fx:id="passwordError" styleClass="field-error"
                           visible="false" managed="false"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="CONFIRMER LE MOT DE PASSE" styleClass="field-label"/>
                    <PasswordField fx:id="confirmField" styleClass="dark-input"
                                   promptText="Répétez le mot de passe" maxWidth="Infinity"/>
                    <Label fx:id="confirmError" styleClass="field-error"
                           visible="false" managed="false"/>
                </VBox>

                <!-- Règles -->
                <VBox spacing="3" style="-fx-background-color: rgba(255,255,255,0.04);
                                         -fx-background-radius: 8; -fx-padding: 10 12;">
                    <Label fx:id="rule1" text="✗  Au moins 8 caractères"
                           style="-fx-text-fill: #606090; -fx-font-size: 11px;"/>
                    <Label fx:id="rule2" text="✗  Une majuscule"
                           style="-fx-text-fill: #606090; -fx-font-size: 11px;"/>
                    <Label fx:id="rule3" text="✗  Un chiffre"
                           style="-fx-text-fill: #606090; -fx-font-size: 11px;"/>
                    <Label fx:id="rule4" text="✗  Un caractère spécial"
                           style="-fx-text-fill: #606090; -fx-font-size: 11px;"/>
                </VBox>

                <Label fx:id="globalMessage" styleClass="global-error"
                       maxWidth="Infinity" wrapText="true"
                       visible="false" managed="false"/>

                <Button text="🔒  Réinitialiser le mot de passe"
                        styleClass="submit-btn" maxWidth="Infinity"
                        onAction="#onReset"/>
            </VBox>
        </VBox>
    </VBox>
</ScrollPane>