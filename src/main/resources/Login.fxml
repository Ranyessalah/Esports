<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.LoginController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="signup-scroll">

    <VBox styleClass="signup-bg-overlay" alignment="CENTER"
          minHeight="600" spacing="0">
        <padding><Insets top="30" bottom="30" left="20" right="20" /></padding>

        <VBox styleClass="signup-card" spacing="0" alignment="CENTER"
              maxWidth="460" minWidth="280">
            <padding><Insets top="36" bottom="36" left="32" right="32" /></padding>

            <StackPane alignment="CENTER" styleClass="trophy-icon-container">
                <Label text="🎮" styleClass="trophy-icon" />
            </StackPane>

            <Label text="Bon retour !" styleClass="signup-title"
                   wrapText="true" textAlignment="CENTER"
                   maxWidth="Infinity" alignment="CENTER" />
            <Label text="Connectez-vous à votre compte ClutchX"
                   styleClass="signup-subtitle" wrapText="true"
                   textAlignment="CENTER" maxWidth="Infinity" alignment="CENTER" />

            <VBox spacing="12" styleClass="form-fields">
                <VBox.margin><Insets top="24" /></VBox.margin>

                <Button styleClass="social-btn" maxWidth="Infinity" onAction="#onGoogleLogin">
                    <graphic>
                        <HBox alignment="CENTER" spacing="10">
                            <StackPane styleClass="social-icon-circle">
                                <!-- Replace with your Google SVG ImageView -->
                                <ImageView fitWidth="16" fitHeight="16" preserveRatio="true">
                                    <image>
                                        <Image url="@/images/google.png" />
                                    </image>
                                </ImageView>
                            </StackPane>
                            <Label text="Google" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        </HBox>
                    </graphic>
                </Button>

                <Button styleClass="social-btn" maxWidth="Infinity" onAction="#onFaceIdLogin">
                    <graphic>
                        <HBox alignment="CENTER" spacing="10">
                            <StackPane styleClass="social-icon-circle">
                                <ImageView fitWidth="16" fitHeight="16" preserveRatio="true">
                                    <image>
                                        <Image url="@/images/face-id.png" />
                                    </image>
                                </ImageView>
                            </StackPane>
                            <Label text="Face ID" style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        </HBox>
                    </graphic>
                </Button>

                <HBox alignment="CENTER" spacing="12">
                    <Separator HBox.hgrow="ALWAYS" styleClass="dark-separator" />
                    <Label text="OU" styleClass="divider-label" />
                    <Separator HBox.hgrow="ALWAYS" styleClass="dark-separator" />
                </HBox>

                <!-- EMAIL -->
                <VBox spacing="4">
                    <Label text="EMAIL" styleClass="field-label" />
                    <TextField fx:id="emailField" styleClass="dark-input"
                               promptText="exemple@email.com" maxWidth="Infinity" />
                    <Label fx:id="emailError" styleClass="field-error"
                           visible="false" managed="false" />
                </VBox>

                <!-- MOT DE PASSE -->
                <VBox spacing="4">
                    <Label text="MOT DE PASSE" styleClass="field-label" />
                    <PasswordField fx:id="passwordField" styleClass="dark-input"
                                   promptText="Entrez votre mot de passe" maxWidth="Infinity" />
                    <Label fx:id="passwordError" styleClass="field-error"
                           visible="false" managed="false" />
                </VBox>

                <HBox alignment="CENTER_LEFT">
                    <CheckBox fx:id="rememberMe" styleClass="dark-checkbox"
                              text="Se souvenir de moi" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button text="Mot de passe oublié ?"
                            styleClass="link-btn" onAction="#onForgotPassword" />
                </HBox>

                <VBox spacing="6">
                    <Label text="Vérification" styleClass="field-label"/>

                    <StackPane fx:id="captchaContainer"
                               prefHeight="78"
                               maxHeight="78"
                               style="-fx-background-color: transparent;" />

                    <Label fx:id="captchaError"
                           styleClass="field-error"
                           visible="false" managed="false"/>
                </VBox>


                <!-- GLOBAL ERROR (wrong credentials) -->
                <Label fx:id="globalError" styleClass="global-error"
                       maxWidth="Infinity" wrapText="true"
                       visible="false" managed="false" />

                <Button text="→  Se connecter" styleClass="submit-btn"
                        maxWidth="Infinity" onAction="#onLogin" />

                <Label text="Pas encore de compte ?" styleClass="signup-hint"
                       textAlignment="CENTER" alignment="CENTER" maxWidth="Infinity" />

                <HBox spacing="12" alignment="CENTER">
                    <Button text="🎮  Inscription Joueur"
                            styleClass="signup-outline-btn"
                            onAction="#onSignupPlayer" />
                    <Button text="🏆  Inscription Coach"
                            styleClass="signup-outline-btn"
                            onAction="#onSignupCoach" />
                </HBox>

            </VBox>
        </VBox>
    </VBox>
</ScrollPane>
