<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AdminProfileViewController"
            styleClass="profile-screen-root" stylesheets="@/admin-theme.css">

    <!-- ── Top bar with back button ── -->
    <top>
        <HBox styleClass="profile-topbar" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="0" bottom="0" left="20" right="28"/></padding>
            <Button text="← Retour" styleClass="back-btn" onAction="#onBack"/>
            <Label text="Mon profil" styleClass="profile-topbar-title"/>
        </HBox>
    </top>

    <!-- ── Scrollable content — card centered with max-width ── -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="profile-scroll">

            <!-- Outer centering wrapper: fills full width, centers child -->
            <StackPane minHeight="0">
                <padding><Insets top="40" bottom="48" left="24" right="24"/></padding>

                <!-- Card: grows up to 560px, shrinks gracefully on narrow windows -->
                <VBox styleClass="profile-card" spacing="0"
                      maxWidth="560" minWidth="320"
                      StackPane.alignment="TOP_CENTER">

                    <!-- Banner -->
                    <VBox styleClass="profile-card-banner" alignment="CENTER" spacing="12">
                        <padding><Insets top="36" bottom="28" left="28" right="28"/></padding>
                        <Label fx:id="avatarLabel"   styleClass="profile-avatar"/>
                        <Label fx:id="nameLabel"     styleClass="profile-name"/>
                        <Label fx:id="emailSubLabel" styleClass="profile-email-sub"/>
                        <Label fx:id="badgeLabel"    styleClass="profile-role-badge"/>
                        <HBox alignment="CENTER" spacing="6">
                            <Label fx:id="onlineDot"   text="●" styleClass="profile-online-dot"/>
                            <Label fx:id="onlineLabel" styleClass="profile-online-text"/>
                        </HBox>
                    </VBox>

                    <!-- Info rows -->
                    <VBox styleClass="profile-rows">

                        <HBox styleClass="profile-row" alignment="CENTER_LEFT" spacing="16">
                            <StackPane styleClass="row-icon-box">
                                <Label text="📧" styleClass="row-icon"/>
                            </StackPane>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Email" styleClass="row-label"/>
                                <Label fx:id="rowEmail" styleClass="row-value"/>
                            </VBox>
                        </HBox>

                        <HBox styleClass="profile-row" alignment="CENTER_LEFT" spacing="16">
                            <StackPane styleClass="row-icon-box">
                                <Label text="🛡" styleClass="row-icon"/>
                            </StackPane>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Rôle" styleClass="row-label"/>
                                <Label fx:id="rowRole" styleClass="row-value"/>
                            </VBox>
                        </HBox>

                        <HBox styleClass="profile-row" alignment="CENTER_LEFT" spacing="16">
                            <StackPane styleClass="row-icon-box">
                                <Label text="⚡" styleClass="row-icon"/>
                            </StackPane>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Statut du compte" styleClass="row-label"/>
                                <Label fx:id="rowStatus" styleClass="row-value"/>
                            </VBox>
                        </HBox>

                        <HBox styleClass="profile-row" alignment="CENTER_LEFT" spacing="16">
                            <StackPane styleClass="row-icon-box">
                                <Label text="📁" styleClass="row-icon"/>
                            </StackPane>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Type" styleClass="row-label"/>
                                <Label fx:id="rowType" styleClass="row-value"/>
                            </VBox>
                        </HBox>

                        <HBox styleClass="profile-row profile-row-last"
                              alignment="CENTER_LEFT" spacing="16">
                            <StackPane styleClass="row-icon-box">
                                <Label text="🔐" styleClass="row-icon"/>
                            </StackPane>
                            <VBox spacing="2" HBox.hgrow="ALWAYS">
                                <Label text="Authentification 2FA" styleClass="row-label"/>
                                <Label fx:id="rowTotp" styleClass="row-value"/>
                            </VBox>
                        </HBox>

                    </VBox>

                    <!-- Card footer -->
                    <HBox styleClass="profile-card-footer" alignment="CENTER_RIGHT" spacing="12">
                        <padding><Insets top="20" bottom="20" left="24" right="24"/></padding>
                        <Button text="✏  Modifier le profil"
                                styleClass="btn-primary" onAction="#onEdit"/>
                    </HBox>

                </VBox>
            </StackPane>
        </ScrollPane>
    </center>

</BorderPane>