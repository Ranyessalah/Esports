<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.gestion_match.MatchClientController"
            stylesheets="@admin.css"
            styleClass="root">

    <!-- MAIN -->
    <center>
        <VBox spacing="20" styleClass="main-content">
            <padding>
                <Insets top="30" right="40" bottom="30" left="40"/>
            </padding>

            <!-- HEADER -->
            <!-- HEADER WITH NAVBAR -->
            <VBox spacing="12">

                <HBox alignment="CENTER_LEFT" spacing="16">

                    <!-- LEFT TEXT -->
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Matchs E-Sports" styleClass="page-title"/>
                        <Label text="Suivez les matchs en direct et consultez les résultats."
                               styleClass="page-subtitle"/>
                    </VBox>

                    <!-- NAVBAR BUTTONS -->
                    <HBox spacing="10" alignment="CENTER">

                        <Button text="Matchs" styleClass="nav-btn active" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: linear-gradient(to right, #5b21b6, #7c3aed); -fx-background-insets: 0; -fx-background-radius: 10; -fx-text-fill: white;"/>
                        <Button text="Équipes" styleClass="nav-btn" onAction="#goEquipes" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: transparent; -fx-background-insets: 0;"/>
                        <Button text="Statistiques" styleClass="nav-btn" onAction="#goStats" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: transparent; -fx-background-insets: 0;"/>
                        <Button text="🚪 Déconnexion" styleClass="nav-btn nav-logout" onAction="#logout" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"
                                style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-text-fill: #ff6b6b;" />

                    </HBox>

                </HBox>

            </VBox>

            <!-- TOPBAR -->
            <!-- TOPBAR corrigé -->

            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="topbar-box">

                <TextField fx:id="searchField"
                           promptText="Rechercher un match ou une équipe..."
                           onKeyReleased="#search"
                           HBox.hgrow="ALWAYS"
                           styleClass="search-field"/>

                <!-- 🔥 FILTRE STATUT -->
                <ComboBox fx:id="statusFilter"
                          onAction="#search"
                          prefWidth="220"
                          prefHeight="42"
                          promptText="Filtrer par statut"
                          visibleRowCount="4"
                          styleClass="form-combo"
                          style="
              -fx-background-color: linear-gradient(to bottom,#1f2937,#111827);
              -fx-background-radius: 14;
              -fx-border-color: rgba(139,92,246,0.45);
              -fx-border-radius: 14;
              -fx-border-width: 1.2;
              -fx-padding: 0 10 0 10;
              -fx-font-size: 13px;
              -fx-font-weight: bold;
              -fx-text-fill: white;
              -fx-cursor: hand;
          "/>

                <Button text="Actualiser"
                        onAction="#refresh"
                        styleClass="btn-secondary"/>

                <Label fx:id="countLabel"
                       text="0 matchs"
                       styleClass="count-badge"/>

            </HBox>
            <!-- MATCH LIST -->
            <ScrollPane fitToWidth="true"
                        fitToHeight="true"
                        styleClass="scroll-pane-custom"
                        VBox.vgrow="ALWAYS">

                <content>
                    <VBox fx:id="matchContainer"
                          spacing="15"
                          styleClass="cards"/>
                </content>

            </ScrollPane>

        </VBox>
    </center>

</BorderPane>