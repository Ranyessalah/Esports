<!--                    <Label text="Authentification à deux facteurs (2FA)" styleClass="card-section-title"/>-->
<!--                    <Label text="Protégez votre compte avec Google Authenticator" styleClass="card-section-sub"/>-->
<!--                </VBox>-->
<!--            </HBox>-->
<!--            <Label fx:id="twoFaWarning" styleClass="twofa-warning"-->
<!--                   text="2FA non activée — votre compte est moins sécurisé"/>-->
