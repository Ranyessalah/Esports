<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.FaceIdCameraController"
      styleClass="signup-bg-overlay"
      alignment="CENTER" spacing="16"
      prefWidth="480" prefHeight="440">
    <padding><Insets top="20" bottom="20" left="20" right="20"/></padding>

    <Label text="Face ID" styleClass="signup-title"/>
    <Label fx:id="statusLabel" text="Initialisation…"
           styleClass="signup-subtitle" wrapText="true"
           textAlignment="CENTER" maxWidth="Infinity" alignment="CENTER"/>

    <StackPane>
        <!-- Camera feed -->
        <ImageView fx:id="cameraView"
                   fitWidth="380" fitHeight="285"
                   preserveRatio="true"
                   style="-fx-border-color: #7b2ff7; -fax-border-width: 2; -fx-border-radius: 8;"/>
        <!-- Countdown overlay -->
        <Label fx:id="countdownLabel" text=""
               style="-fx-font-size: 64px; -fx-text-fill: #7b2ff7;
                      -fx-font-weight: bold; -fx-opacity: 0.85;"/>
    </StackPane>

    <HBox spacing="12" alignment="CENTER">
        <Button fx:id="actionButton" text="Capturer"
                styleClass="submit-btn"
                prefWidth="200" onAction="#onAction"/>
        <Button fx:id="cancelButton" text="Annuler"
                styleClass="signup-outline-btn"
                prefWidth="120" onAction="#onCancel"/>
    </HBox>
</VBox>